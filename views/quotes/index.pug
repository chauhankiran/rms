extends ../layout
include ../mixins/pagination

block content
  .row.align-items-center 
    .col-8 
      h1 #{title} (#{count})
    .col-4.text-end 
      a(href="/quotes/new").btn New quote
    
    .col-12
      form(action="/quotes", method="get") 
        .form-group 
          input(type="hidden", name="orderBy", value=orderBy)
          input(type="hidden", name="orderDir", value=orderDir)
          input(type="text", name="search", value=search, autofocus=true, placeholder="Type name and press Enter")

      include ../partials/flash

      table 
        thead 
          tr 
            th 
            each header in headers
              //- id
              if header === "id"
                th
                  if orderDir === 'ASC'
                    a(href=`/quotes?orderBy=id&orderDir=DESC${search ? `&search=${search}` : ''}`) #{quoteFields[header]}
                  else 
                    a(href=`/quotes?orderBy=id&orderDir=ASC${search ? `&search=${search}` : ''}`) #{quoteFields[header]}
                  
                  if orderBy === 'id'
                    span.order-wrapper= orderDir
              
              //- name
              if header === "name"
                th
                  if orderDir === 'ASC'
                    a(href=`/quotes?orderBy=name&orderDir=DESC${search ? `&search=${search}` : ''}`) #{quoteFields[header]}
                  else 
                    a(href=`/quotes?orderBy=name&orderDir=ASC${search ? `&search=${search}` : ''}`) #{quoteFields[header]}
                  
                  if orderBy === 'name'
                    span.order-wrapper= orderDir
              
              //- updatedBy
              if header === "updatedBy"
                th #{quoteFields[header]}
              
              //- updatedAt
              if header === "updatedAt"
                th
                  if orderDir === 'ASC'
                    a(href=`/quotes?orderBy=updatedAt&orderDir=DESC${search ? `&search=${search}` : ''}`) #{quoteFields[header]}
                  else 
                    a(href=`/quotes?orderBy=updatedAt&orderDir=ASC${search ? `&search=${search}` : ''}`) #{quoteFields[header]}
                  
                  if orderBy === 'updatedAt'
                    span.order-wrapper= orderDir

        tbody 
          if quotes.length > 0
            each quote in quotes 
              tr
                td 
                  input(type="checkbox", name="quoteId", value= quote.id)
                td
                  a(href=`/quotes/${quote.id}`) #{quote.id}
                td #{quote.name}
                  if (!quote.isActive)
                    span.archive-status (archived)
                td #{quote.updatedByEmail || "-" }
                td #{quote.updatedAt || "-" } 
          else 
            tr 
              td(colspan=7).text-center No quotes found.