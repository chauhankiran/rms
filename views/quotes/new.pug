extends ../layout

block content
  .row 
    .col-6 
      h1= title

      include ../partials/flash

      form(action="/quotes", method="post") 
        .form-group 
          label(for="name") #{quoteFields.name}
          input(type="text", name="name", placeholder="42 New LED Monitors", autofocus=true)#name
        
        .form-group 
          label(for="total") #{quoteFields.total}
          input(type="text", name="total", placeholder="1200", autofocus=true)#total

        .form-group 
          label(for="description") #{quoteFields.description}
          textarea(name="description", cols="30", rows="10", placeholder="Add informative optional description")#description
        
        .form-group 
          .row.align-items-center 
            .col-6 
              button(type="submit") Create quote
            .col-6.text-end
              a(href="/quotes").btn.is-muted Cancel