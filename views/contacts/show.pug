extends ../layout

block content
  .row.align-items-center 
    .col-6 
      h1= title
    .col-6.text-end 
      a(href="/contacts").btn.is-muted.mr-4 &larr; Back 
      .dropdown
        button.dropdown-trigger Actions
        .dropdown-menu
          .dropdown-content 
            a(href=`/contacts/${contact.id}/edit`).dropdown-item Edit contact
            button.dropdown-item(onclick="activeContact()") Active contact
            button.dropdown-item(onclick="archiveContact()") Archive contact
            button.dropdown-item(onclick="deleteContact()") Delete contact

    .col-12
      include ../partials/flash

    .col-12 
      .row 
        if contactFields.prefix
          .col-12.mb-4
            label(for="prefix").field-name #{contactFields.prefix} 
            span.field-value #{contact.prefix}

        if contactFields.firstName
          .col-12.mb-4
            label(for="firstName").field-name #{contactFields.firstName}
            span.field-value #{contact.firstName}
              if !contact.isActive 
                span.archive-status (archived)
        
        if contactFields.lastName
          .col-12.mb-4
            label(for="lastName").field-name #{contactFields.lastName}
            span.field-value #{contact.lastName}

        if contactFields.annualRevenue
          .col-12.mb-4
            label(for="annualRevenue").field-name #{contactFields.annualRevenue}
            span.field-value #{contact.annualRevenue}

        if contactFields.contactIndustryId
          .col-12.mb-4
            label(for="contactIndustry").field-name #{contactFields.contactIndustryId}
            span.field-value #{contact.contactIndustry}

        if contactFields.description
          .col-12.mb-4
            label(for="description").field-name #{contactFields.description}
            span.field-value #{contact.description || "-"}
        
        if contactFields.createdAt
          .col-6.mb-4
            label(for="createdAt").field-name #{contactFields.createdAt}
            span.field-value #{contact.createdAt || "-"}
        
        if contactFields.updatedAt
          .col-6.mb-4
            label(for="updatedAt").field-name #{contactFields.updatedAt}
            span.field-value #{contact.updatedAt || "-"}

        if contactFields.updatedAt
          .col-6.mb-4
            label(for="createdBy").field-name #{contactFields.updatedAt}
            span.field-value #{contact.createdByEmail || "-"}
        
        if contactFields.updatedBy
          .col-6.mb-4
            label(for="updatedBy").field-name #{contactFields.updatedBy}
            span.field-value #{contact.updatedByEmail || "-"}


      form(action=`/contacts/${contact.id}?_method=DELETE`, name="deleteContactForm", method="post")

      form(action=`/contacts/${contact.id}/active?_method=PUT`, name="activeContactForm", method="post")

      form(action=`/contacts/${contact.id}/archive?_method=PUT`, name="archiveContactForm", method="post")