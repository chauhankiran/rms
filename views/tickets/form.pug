//- name
if ticketFields.name
  .form-group 
    label(for="name") #{ticketFields.name}
    input(type="text", name="name", id="name" value=ticket ? ticket.name : "", placeholder="Website is not loading", autofocus=true)
        
//- ticketTypeId
if ticketFields.ticketTypeId
  .form-group 
    label(for="ticketTypeId") #{ticketFields.ticketTypeId}
    select(name="ticketTypeId", id="ticketTypeId")
      for ticketType in ticketTypes
        option(value=ticketType.id, selected=ticket && ticketType.id == ticket.ticketTypeId) #{ticketType.name}

//- description
ticketFields.description
  .form-group 
    label(for="description") #{ticketFields.description}
    textarea(name="description", id="description", cols="30", rows="10", placeholder="Add informative optional description") #{ticket ? ticket.description : ""}
