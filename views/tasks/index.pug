extends ../layout
include ../mixins/pagination

block content
  .row.align-items-center 
    .col-8 
      h1 #{title} (#{count})
    .col-4.text-end 
      a(href="/tasks/new").btn New task
    
    .col-12
      form(action="/tasks", method="get") 
        .form-group 
          input(type="hidden", name="orderBy", value=orderBy)
          input(type="hidden", name="orderDir", value=orderDir)
          input(type="text", name="search", value=search, autofocus=true, placeholder="Type name and press Enter")

      include ../partials/flash

      table 
        thead 
          tr 
            th 
            each header in headers
              //- id
              if header === "id" && taskFields.id
                th
                  if orderDir === 'ASC'
                    a(href=`/tasks?orderBy=id&orderDir=DESC${search ? `&search=${search}` : ''}`) #{taskFields[header]}
                  else 
                    a(href=`/tasks?orderBy=id&orderDir=ASC${search ? `&search=${search}` : ''}`) #{taskFields[header]}
                  
                  if orderBy === 'id'
                    span.order-wrapper= orderDir
              
              //- name
              if header === "name" && taskFields.name
                th
                  if orderDir === 'ASC'
                    a(href=`/tasks?orderBy=name&orderDir=DESC${search ? `&search=${search}` : ''}`) #{taskFields[header]}
                  else 
                    a(href=`/tasks?orderBy=name&orderDir=ASC${search ? `&search=${search}` : ''}`) #{taskFields[header]}
                  
                  if orderBy === 'name'
                    span.order-wrapper= orderDir

              //- taskTypeId
              if header === "taskTypeId" && taskFields.taskTypeId
                th #{taskFields[header]}
              
              //- updatedBy
              if header === "updatedBy" && taskFields.updatedBy
                th #{taskFields[header]}
              
              //- updatedAt
              if header === "updatedAt" && taskFields.updatedAt
                th
                  if orderDir === 'ASC'
                    a(href=`/tasks?orderBy=updatedAt&orderDir=DESC${search ? `&search=${search}` : ''}`) #{taskFields[header]}
                  else 
                    a(href=`/tasks?orderBy=updatedAt&orderDir=ASC${search ? `&search=${search}` : ''}`) #{taskFields[header]}
                  
                  if orderBy === 'updatedAt'
                    span.order-wrapper= orderDir

        tbody 
          if tasks.length > 0
            each task in tasks 
              tr
                if taskFields.id
                  td 
                    input(type="checkbox", name="taskId", value= task.id)
                
                if taskFields.id
                  td
                    a(href=`/tasks/${task.id}`) #{task.id}
                
                if taskFields.name
                  td #{task.name}
                    if (!task.isActive)
                      span.archive-status (archived)
                
                if taskFields.taskTypeId
                  td #{task.taskType || "-" }
                
                if taskFields.updatedBy
                  td #{task.updatedByEmail || "-" }

                if taskFields.updatedAt
                  td #{task.updatedAt || "-" } 
          else 
            tr 
              td(colspan=7).text-center No tasks found.
    
    .col-12 
      +pagination(paginationLinks.first, paginationLinks.prev, paginationLinks.next, paginationLinks.last)