extends ../../layout

block content
  .row 
    .col-6 
      h1= title

      include ../../partials/flash

      form(action=`/admin/company-sources/${companySource.id}?_method=PUT`, method="post") 
        .form-group 
          label(for="name") Name
          input(type="text", name="name", value=companySource.name, placeholder="Social Media", autofocus=true)#name

        .form-group 
          .row.align-items-center 
            .col-6 
              button(type="submit") Update company source
            .col-6.text-end
              a(href=`/admin/company-sources/${companySource.id}`).btn.is-muted Cancel
        