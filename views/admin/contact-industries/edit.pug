extends ../../layout

block content
  .row 
    .col-6 
      h1= title

      include ../../partials/flash

      form(action=`/admin/contact-industries/${contactIndustry.id}?_method=PUT`, method="post") 
        .form-group 
          label(for="name") Name
          input(type="text", name="name", value=contactIndustry.name, placeholder="Healthcare", autofocus=true)#name
        
        .form-group 
          .row.align-items-center 
            .col-6 
              button(type="submit") Update contact industry
            .col-6.text-end
              a(href=`/admin/contact-industries/${contactIndustry.id}`).btn.is-muted Cancel
        