extends ../../layout

block content 
  .row.align-items-center 
    .col-6 
      h1= title
    .col-6.text-end 
      a(href=`/admin/company-sources/${companySource.id}/edit`).btn.mr-4 Edit company source
      button(type="button", onClick="deleteCompanySource()") Delete company source

      form(action=`/admin/company-sources/${companySource.id}?_method=DELETE`, name="deleteCompanySourceForm", method="post") 

    .col-12
      include ../../partials/flash

      p Company source is #{companySource.isActive ? 'active' : 'de-active' }. Click the button to #{companySource.isActive ? 'de-active' : 'active' }. 
        button(type="button", onClick="archiveUser()") #{companySource.isActive ? 'De-active' : 'Active' } company source

      form(action=`/admin/company-sources/${companySource.id}/archive?_method=PUT`, name="archiveCompanySourceForm", method="post") 
