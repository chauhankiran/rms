extends ../../layout
include ../../mixins/pagination

block content
    .row.align-items-center 
        .col-12 
            h1 #{title} (#{count})

        .col-12
            form(action="/admin/labels", method="get") 
                .form-group 
                    input(type="hidden", name="orderBy", value=orderBy)
                    input(type="hidden", name="orderDir", value=orderDir)
                    input(type="text", name="search", value=search, autofocus=true, placeholder="Type name and press Enter")

            include ../../partials/flash

            table
                thead 
                    tr  
                        th
                            if orderDir === 'ASC'
                                a(href=`/admin/labels?orderBy=id&orderDir=DESC${search ? `&search=${search}` : ''}`) Id
                            else 
                                a(href=`/admin/labels?orderBy=id&orderDir=ASC${search ? `&search=${search}` : ''}`) Id
                            
                            if orderBy === 'id'
                                span.order-wrapper= orderDir
                
                        th
                            if orderDir === 'ASC'
                                a(href=`/admin/labels?orderBy=displayName&orderDir=DESC${search ? `&search=${search}` : ''}`) Label
                            else 
                                a(href=`/admin/labels?orderBy=displayName&orderDir=ASC${search ? `&search=${search}` : ''}`) Label
                            
                            if orderBy === 'displayName'
                                span.order-wrapper= orderDir

                        th Updated by

                        th Module

                        th
                            if orderDir === 'ASC'
                                a(href=`/admin/labels?orderBy=updatedAt&orderDir=DESC${search ? `&search=${search}` : ''}`) Updated at
                            else 
                                a(href=`/admin/labels?orderBy=updatedAt&orderDir=ASC${search ? `&search=${search}` : ''}`) Updated at
                        
                            if orderBy === 'updatedAt'
                                span.order-wrapper= orderDir
                
                    tbody 
                        if _labels.length > 0
                            each label in _labels 
                                tr
                                    td
                                        a(href=`/admin/labels/${label.id}`) #{label.id}
                                    td 
                                        a(href=`/admin/labels/${label.id}`) #{label.label || "-" }
                    
                                        if !label.isActive 
                                            span.archive-status (not being used)

                                    td= label.module
                                    
                                    td #{label.updatedByEmail || "-" }
                                    
                                    td #{label.updatedAt || "-" } 
                        else 
                            tr 
                                td(colspan=7).text-center No labels found.

        .col-12 
            +pagination(paginationLinks.first, paginationLinks.prev, paginationLinks.next, paginationLinks.last)