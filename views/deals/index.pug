extends ../layout
include ../mixins/pagination

block content
  .row.align-items-center 
    .col-8 
      h1 #{title} (#{count})
    .col-4.text-end 
      a(href="/deals/new").btn New deal
    
    .col-12
      form(action="/deals", method="get") 
        .form-group 
          input(type="hidden", name="orderBy", value=orderBy)
          input(type="hidden", name="orderDir", value=orderDir)
          input(type="text", name="search", value=search, autofocus=true, placeholder="Type name and press Enter")

      include ../partials/flash

      table 
        thead 
          tr 
            th 
            each header in headers
              //- id
              if header === "id"
                th
                  if orderDir === 'ASC'
                    a(href=`/deals?orderBy=id&orderDir=DESC${search ? `&search=${search}` : ''}`) #{dealFields[header]}
                  else 
                    a(href=`/deals?orderBy=id&orderDir=ASC${search ? `&search=${search}` : ''}`) #{dealFields[header]}
                  
                  if orderBy === 'id'
                    span.order-wrapper= orderDir
              
              //- name
              if header === "name"
                th
                  if orderDir === 'ASC'
                    a(href=`/deals?orderBy=name&orderDir=DESC${search ? `&search=${search}` : ''}`) #{dealFields[header]}
                  else 
                    a(href=`/deals?orderBy=name&orderDir=ASC${search ? `&search=${search}` : ''}`) #{dealFields[header]}
                  
                  if orderBy === 'name'
                    span.order-wrapper= orderDir

              //- dealSourceId
              if header === "dealSourceId"
                th #{dealFields[header]}
              
              //- updatedBy
              if header === "updatedBy"
                th #{dealFields[header]}
              
              //- updatedAt
              if header === "updatedAt"
                th
                  if orderDir === 'ASC'
                    a(href=`/deals?orderBy=updatedAt&orderDir=DESC${search ? `&search=${search}` : ''}`) #{dealFields[header]}
                  else 
                    a(href=`/deals?orderBy=updatedAt&orderDir=ASC${search ? `&search=${search}` : ''}`) #{dealFields[header]}
                  
                  if orderBy === 'updatedAt'
                    span.order-wrapper= orderDir

        tbody 
          if deals.length > 0
            each deal in deals 
              tr
                td 
                  input(type="checkbox", name="dealId", value= deal.id)
                td
                  a(href=`/deals/${deal.id}`) #{deal.id}
                td #{deal.name}
                  if (!deal.isActive)
                    span.archive-status (archived)
                td #{deal.dealSource || "-" }
                td #{deal.updatedByEmail || "-" }
                td #{deal.updatedAt || "-" } 
          else 
            tr 
              td(colspan=7).text-center No deals found.