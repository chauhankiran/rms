nav.nav
  .nav-start
    a(href="/").nav-brand Home
    if currentUser
      a(href="/companies").nav-item Companies
      a(href="/contacts").nav-item Contacts
  .nav-end
    if currentUser
      a(href="/users").nav-item Users
      a(href="/auth/logout").nav-item Logout
    else
      a(href="/auth/login").nav-item Login
      a(href="/auth/register").nav-item Register
