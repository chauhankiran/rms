extends ../layout

block content
  .row.align-items-center 
    .col-8 
      h1= title
    .col-4.text-end 
      a(href="/users/new").btn New user

    .col-12
      include ../partials/flash

      table
        thead 
          tr 
            th Id 
            th Email
        tbody 
          if users.length > 0
            each user in users 
              tr 
                td
                  a(href=`/users/${user.id}`) #{user.id}
                td #{user.email}
          else 
            tr 
              td(colspan=2).text-center No users found.